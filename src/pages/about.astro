---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import aboutUs from '../images/about-us.png';
import roofRepair from '../images/roof-repair.png';
---

<Layout title="About Us" description="Learn about Oak Ridge Roofing Co. - your trusted local roofing contractor serving Oak Ridge and the greater Knoxville area for over 20 years.">

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <h1>About Oak Ridge Roofing Co.</h1>
      <p class="hero-subtitle">Serving East Tennessee homeowners with integrity, quality, and craftsmanship since 2003.</p>
    </div>
  </section>

  <!-- Story Section -->
  <section class="section-pad">
    <div class="container">
      <div class="story-grid">
        <div class="story-content">
          <h2>Our Story</h2>
          <p>Oak Ridge Roofing Co. was founded with a simple mission: provide honest, high-quality roofing services that East Tennessee homeowners could trust. What started as a small family operation in 2003 has grown into one of the region's most trusted roofing contractors.</p>
          <p>We're proud to call Oak Ridge home. Our community is our family, and every roof we install, every repair we make, is a reflection of our commitment to this place we all share. We know what Tennessee weather does to roofs, and we build accordingly.</p>
          <p>As a locally owned and operated business, we answer to our neighbors, not some distant corporate office. That means we do the job right the first time, use quality materials, and stand behind our work.</p>
        </div>
        <div class="story-image">
          <Image src={aboutUs} alt="Oak Ridge Roofing team" />
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section-pad-alt values">
    <div class="container">
      <h2>Our Values</h2>
      <div class="values-grid">
        <div class="value-card">
          <div class="value-icon">
            <svg aria-hidden="true" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
            </svg>
          </div>
          <h3>Integrity</h3>
          <p>Honest assessments, transparent pricing, and no unnecessary upsells. We recommend only what your roof actually needs.</p>
        </div>
        <div class="value-card">
          <div class="value-icon">
            <svg aria-hidden="true" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
            </svg>
          </div>
          <h3>Community</h3>
          <p>We're your neighbors. Every roof we touch affects our community's value and safety. We take that seriously.</p>
        </div>
        <div class="value-card">
          <div class="value-icon">
            <svg aria-hidden="true" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
          </div>
          <h3>Quality</h3>
          <p>Premium materials, skilled craftsmen, and attention to detail. Our work is built to last through Tennessee seasons.</p>
        </div>
        <div class="value-card">
          <div class="value-icon">
            <svg aria-hidden="true" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
              <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
            </svg>
          </div>
          <h3>Responsiveness</h3>
          <p>When you call, we answer. When you have a problem, we respond fast. Emergency service available 24/7.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="section-pad team">
    <div class="container">
      <h2>Meet Our Team</h2>
      <p class="team-intro">Our crew is made up of skilled tradespeople who take pride in their craft. From estimators to installers, everyone on our team is committed to doing the job right.</p>
      <div class="team-grid">
        <div class="team-card">
          <div class="team-avatar">
            <Image src={roofRepair} alt="Roofing professional" />
          </div>
          <h3>Mike Richardson</h3>
          <p class="team-role">Founder & Lead Estimator</p>
          <p class="team-bio">20+ years in residential roofing. Mike founded the company with a simple belief: homeowners deserve honest service and quality work.</p>
        </div>
        <div class="team-card">
          <div class="team-avatar">
            <Image src={roofRepair} alt="Roofing professional" />
          </div>
          <h3>Carlos Mendez</h3>
          <p class="team-role">Installation Supervisor</p>
          <p class="team-bio">Lead installer with expertise in asphalt shingles, metal roofing, and flat roof systems. Certified by major manufacturers.</p>
        </div>
        <div class="team-card">
          <div class="team-avatar">
            <Image src={roofRepair} alt="Roofing professional" />
          </div>
          <h3>David Chen</h3>
          <p class="team-role">Insurance Claims Specialist</p>
          <p class="team-bio">Helps homeowners navigate the insurance claims process. Has assisted hundreds of families in getting their storm damage covered.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section-pad-alt stats">
    <div class="container">
      <div class="stats-grid">
        <div class="stat">
          <span class="stat-number">20+</span>
          <span class="stat-label">Years in Business</span>
        </div>
        <div class="stat">
          <span class="stat-number">2,500+</span>
          <span class="stat-label">Roofs Completed</span>
        </div>
        <div class="stat">
          <span class="stat-number">100%</span>
          <span class="stat-label">Licensed & Insured</span>
        </div>
        <div class="stat">
          <span class="stat-number">4.9</span>
          <span class="stat-label">Average Rating</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-pad cta">
    <div class="container">
      <h2>Ready to Work With Us?</h2>
      <p>Whether you need a quick repair or a full roof replacement, we're here to help. Get a free inspection and estimate today.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn btn-primary">Schedule Free Inspection</a>
        <a href="tel:+15551234567" class="btn btn-secondary">Call (555) 123-4567</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, #4A3E2B 100%);
    color: var(--color-surface);
    padding: var(--space-16) 0;
    text-align: center;
  }

  .page-hero h1 { color: var(--color-surface); margin-bottom: var(--space-4); }
  .hero-subtitle { font-size: var(--font-size-body-lg); color: rgba(255, 255, 255, 0.9); max-width: 600px; margin: 0 auto; }

  .section-pad { padding: var(--space-16) 0; }
  .section-pad-alt { padding: var(--space-16) 0; background: var(--color-surface); }

  /* Story */
  .story-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  @media (min-width: 64rem) {
    .story-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .story-content h2 { margin-bottom: var(--space-4); }
  .story-content p { color: var(--color-text-muted); line-height: 1.8; margin-bottom: var(--space-4); }
  .story-content p:last-child { margin-bottom: 0; }

  .story-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4/3;
  }

  .story-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Values */
  .values h2 { text-align: center; margin-bottom: var(--space-12); }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 48rem) {
    .values-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 64rem) {
    .values-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .value-card {
    text-align: center;
    padding: var(--space-6);
    background: var(--color-background);
    border-radius: var(--radius-lg);
  }

  .value-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    margin: 0 auto var(--space-4);
    background: var(--color-surface);
    border-radius: 50%;
    color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }

  .value-card h3 { margin-bottom: var(--space-2); }
  .value-card p { font-size: 0.875rem; color: var(--color-text-muted); margin: 0; }

  /* Team */
  .team h2 { text-align: center; margin-bottom: var(--space-4); }
  .team-intro { text-align: center; color: var(--color-text-muted); max-width: 600px; margin: 0 auto var(--space-12); }

  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 48rem) {
    .team-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .team-card {
    background: var(--color-background);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    text-align: center;
  }

  .team-avatar {
    width: 120px;
    height: 120px;
    margin: 0 auto var(--space-4);
    border-radius: 50%;
    overflow: hidden;
  }

  .team-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .team-card h3 { margin-bottom: var(--space-1); font-size: 1.125rem; }
  .team-role { color: var(--color-primary); font-weight: 600; font-size: 0.875rem; margin-bottom: var(--space-3); }
  .team-bio { font-size: 0.875rem; color: var(--color-text-muted); margin: 0; line-height: 1.6; }

  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
    text-align: center;
  }

  @media (min-width: 48rem) {
    .stats-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .stat-number {
    display: block;
    font-family: var(--font-headline);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    display: block;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-top: var(--space-2);
  }

  /* CTA */
  .cta { text-align: center; }
  .cta h2 { margin-bottom: var(--space-4); }
  .cta p { color: var(--color-text-muted); max-width: 500px; margin: 0 auto var(--space-8); }

  .cta-buttons {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: center;
  }

  @media (min-width: 48rem) {
    .cta-buttons { flex-direction: row; justify-content: center; }
  }

  .btn { display: inline-flex; align-items: center; justify-content: center; gap: var(--space-2); font-family: var(--font-body); font-size: 1rem; font-weight: 600; padding: var(--space-4) var(--space-6); border-radius: var(--radius-md); text-decoration: none; min-height: 52px; transition: all 150ms ease; }
  .btn-primary { background: var(--color-accent); color: var(--color-primary); }
  .btn-primary:hover { filter: brightness(1.1); transform: translateY(-1px); }
  .btn-secondary { background: var(--color-primary); color: var(--color-surface); }
  .btn-secondary:hover { background: #4A3E2B; }
</style>
