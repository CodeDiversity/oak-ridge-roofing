---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroHome from '../images/hero-home.png';
import oldRoof from '../images/old-roof.png';
import newRoof from '../images/new-roof.png';

const services = [
  {
    title: 'Roofing Services',
    description: 'Complete roof installation and replacement for residential and commercial properties.',
    icon: 'roof',
    link: '/services',
  },
  {
    title: 'Roof Repair',
    description: 'Fix leaks, replace missing shingles, and address storm damage before it worsens.',
    icon: 'repair',
    link: '/repair',
  },
  {
    title: 'Storm Damage',
    description: 'Hail and wind damage assessment with insurance claim assistance.',
    icon: 'storm',
    link: '/storm-damage',
  },
  {
    title: 'Gutters & Inspections',
    description: 'Gutter installation, cleaning, and comprehensive roof inspections.',
    icon: 'gutter',
    link: '/services',
  },
];

const trustItems = [
  { label: 'Licensed & Insured', icon: 'shield' },
  { label: 'Locally Owned', icon: 'location' },
  { label: 'Emergency Repairs', icon: 'alert' },
  { label: 'Free Estimates', icon: 'estimate' },
];

const reviews = [
  {
    name: 'Sarah Mitchell',
    location: 'Oak Ridge, TN',
    rating: 5,
    text: 'Oak Ridge Roofing fixed our storm damage quickly. They handled everything with our insurance company and the new roof looks amazing.',
  },
  {
    name: 'James Crawford',
    location: 'Knoxville, TN',
    rating: 5,
    text: 'Professional from start to finish. Fair pricing, clean worksite, and the crew was respectful of our landscaping.',
  },
  {
    name: 'Patricia Holmes',
    location: 'Maryville, TN',
    rating: 5,
    text: 'After three other companies gave me the runaround, Oak Ridge actually showed up and solved my leak problem in one day.',
  },
];

const faqs = [
  {
    question: 'How long does a roof replacement take?',
    answer: 'Most residential roof replacements are completed in 1-3 days, depending on the size and complexity of your roof. We work efficiently while maintaining quality craftsmanship.',
  },
  {
    question: 'Do you work with insurance companies?',
    answer: 'Yes. We have extensive experience with insurance claims and can help guide you through the process, including meeting with adjusters and providing documentation.',
  },
  {
    question: 'What warranties do you offer?',
    answer: 'We offer a 10-year workmanship warranty on all installations, plus manufacturer warranties on materials (typically 25-50 years on shingles).',
  },
  {
    question: 'How do I know if I need a repair or full replacement?',
    answer: 'During our free inspection, we assess your roof condition and provide honest recommendations. We will never recommend unnecessary work.',
  },
  {
    question: 'Do you provide free estimates?',
    answer: 'Absolutely. We offer free, no-obligation estimates for all services. Our inspections are thorough and include a detailed written report.',
  },
];

const serviceAreas = [
  'Oak Ridge',
  'Knoxville',
  'Maryville',
  'Alcoa',
  'Lenoir City',
  'Clinton',
  'Farragut',
  'Sevierville',
  ' Seymour',
  'Louisville',
];
---

<Layout title="Home" description="Oak Ridge Roofing Co. provides professional roofing services in Oak Ridge, TN and surrounding areas. Free estimates available.">

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg">
      <Image src={heroHome} alt="Beautiful home with new roof" />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content container">
      <h1>Your Roof. Our Promise.</h1>
      <p class="hero-subtitle">Professional roofing services you can trust. Serving Oak Ridge and the greater Knoxville area with integrity and quality craftsmanship.</p>
      <div class="hero-cta">
        <a href="#contact" class="btn btn-primary">Get a Free Roof Inspection</a>
        <a href="tel:+15551234567" class="btn btn-secondary">
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          Call (555) 123-4567
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="trust-bar">
    <div class="container">
      <ul class="trust-list">
        {trustItems.map((item) => (
          <li class="trust-item">
            <span class="trust-icon" data-icon={item.icon}>
              {item.icon === 'shield' && (
                <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
                </svg>
              )}
              {item.icon === 'location' && (
                <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                </svg>
              )}
              {item.icon === 'alert' && (
                <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/>
                </svg>
              )}
              {item.icon === 'estimate' && (
                <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm-1 7V3.5L18.5 9H13z"/>
                </svg>
              )}
            </span>
            <span class="trust-label">{item.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services section-pad" id="services">
    <div class="container">
      <h2 class="section-title">Our Services</h2>
      <p class="section-subtitle">Comprehensive roofing solutions for every need</p>
      <div class="services-grid">
        {services.map((service) => (
          <a href={service.link} class="service-card">
            <div class="service-icon">
              {service.icon === 'roof' && (
                <svg aria-hidden="true" width="48" height="48" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2L2 8l10 6 10-6-10-6zM2 14l10 6 10-6M2 18l10 6 10-6"/>
                </svg>
              )}
              {service.icon === 'repair' && (
                <svg aria-hidden="true" width="48" height="48" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>
                </svg>
              )}
              {service.icon === 'storm' && (
                <svg aria-hidden="true" width="48" height="48" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.92 7.02C17.45 4.18 14.97 2 12 2 9.82 2 7.83 3.18 6.78 5.06 4.09 5.41 2 7.74 2 10.5 2 13.53 4.47 16 7.5 16h10c2.48 0 4.5-2.02 4.5-4.5 0-2.34-1.79-4.27-4.08-4.48zM11 15l1.5-4.5H9L12 7l-1.5 4.5h3L11 15z"/>
                </svg>
              )}
              {service.icon === 'gutter' && (
                <svg aria-hidden="true" width="48" height="48" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 3L2 12h3v8h14v-8h3L12 3zm5 15H7v-6.19l5-4.5 5 4.5V18z"/>
                </svg>
              )}
            </div>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
            <span class="service-link">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Before/After Section -->
  <section class="before-after section-pad-alt">
    <div class="container">
      <h2 class="section-title">Transformation Gallery</h2>
      <p class="section-subtitle">See the difference professional roofing makes</p>
      <div class="ba-grid">
        <div class="ba-item">
          <div class="ba-image before">
            <Image src={oldRoof} alt="Damaged roof showing wear and missing shingles" />
            <span class="ba-label">Before</span>
          </div>
          <p class="ba-caption">Aged roof with storm damage</p>
        </div>
        <div class="ba-item">
          <div class="ba-image after">
            <Image src={newRoof} alt="Newly installed architectural shingle roof" />
            <span class="ba-label">After</span>
          </div>
          <p class="ba-caption">New architectural shingles installed</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews Section -->
  <section class="reviews section-pad">
    <div class="container">
      <h2 class="section-title">What Our Customers Say</h2>
      <p class="section-subtitle">Trusted by homeowners across East Tennessee</p>
      <div class="reviews-grid">
        {reviews.map((review) => (
          <div class="review-card">
            <div class="review-stars" aria-label={`${review.rating} out of 5 stars`}>
              {Array(review.rating).fill(null).map(() => (
                <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                </svg>
              ))}
            </div>
            <p class="review-text">"{review.text}"</p>
            <div class="review-author">
              <strong>{review.name}</strong>
              <span>{review.location}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="areas section-pad-alt">
    <div class="container">
      <h2 class="section-title">Service Areas</h2>
      <p class="section-subtitle">Proudly serving communities throughout the greater Oak Ridge area</p>
      <ul class="areas-list">
        {serviceAreas.map((area) => (
          <li>{area}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq section-pad" id="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-question">
              {faq.question}
              <svg aria-hidden="true" class="faq-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M16.59 8.59L12 13.17 7.41 8.59 6 10l6 6 6-6z"/>
              </svg>
            </summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact section-pad-alt" id="contact">
    <div class="container">
      <h2 class="section-title">Get Your Free Inspection</h2>
      <p class="section-subtitle">Fill out the form below and we will contact you within 24 hours</p>
      <form class="contact-form" method="post">
        <div class="form-row">
          <div class="form-group">
            <label for="name">Full Name <span class="required">*</span></label>
            <input type="text" id="name" name="name" required placeholder="John Smith" />
          </div>
          <div class="form-group">
            <label for="email">Email Address <span class="required">*</span></label>
            <input type="email" id="email" name="email" required placeholder="john@example.com" />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="phone">Phone Number <span class="required">*</span></label>
            <input type="tel" id="phone" name="phone" required placeholder="(555) 123-4567" />
          </div>
          <div class="form-group">
            <label for="service">Service Needed <span class="required">*</span></label>
            <select id="service" name="service" required>
              <option value="">Select a service</option>
              <option value="inspection">Free Roof Inspection</option>
              <option value="repair">Roof Repair</option>
              <option value="replacement">Roof Replacement</option>
              <option value="storm">Storm Damage Assessment</option>
              <option value="gutter">Gutter Services</option>
              <option value="other">Other</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label for="message">Tell us about your project</label>
          <textarea id="message" name="message" rows="4" placeholder="Describe your roofing needs..."></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-full">Request Free Inspection</button>
      </form>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    color: var(--color-surface);
    padding: var(--space-24) 0;
    overflow: hidden;
    min-height: 70vh;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(93, 78, 55, 0.85) 0%, rgba(44, 36, 22, 0.9) 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, var(--font-size-headline-xl));
    color: var(--color-surface);
    margin-bottom: var(--space-6);
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, var(--font-size-body-xl));
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: var(--space-8);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-cta {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: center;
  }

  @media (min-width: 48rem) {
    .hero-cta {
      flex-direction: row;
      justify-content: center;
    }
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    padding: var(--space-4) var(--space-6);
    border-radius: var(--radius-md);
    text-decoration: none;
    min-height: 52px;
    transition: all 150ms ease;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-primary);
  }

  .btn-primary:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.15);
    color: var(--color-surface);
    border: 2px solid rgba(255, 255, 255, 0.3);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  .btn-full {
    width: 100%;
  }

  @media (min-width: 48rem) {
    .btn-full {
      width: auto;
    }
  }

  /* Trust Bar */
  .trust-bar {
    background: var(--color-surface);
    padding: var(--space-8) 0;
    border-bottom: 1px solid rgba(93, 78, 55, 0.1);
  }

  .trust-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    list-style: none;
  }

  @media (min-width: 48rem) {
    .trust-list {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    text-align: center;
  }

  .trust-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(93, 78, 55, 0.08);
    border-radius: 50%;
    color: var(--color-primary);
  }

  .trust-label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-text);
  }

  /* Sections */
  .section-pad {
    padding: var(--space-16) 0;
  }

  .section-pad-alt {
    padding: var(--space-16) 0;
    background: var(--color-surface);
  }

  .section-title {
    text-align: center;
    margin-bottom: var(--space-2);
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-muted);
    margin-bottom: var(--space-12);
  }

  /* Services Grid */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 48rem) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 64rem) {
    .services-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .service-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-8);
    background: var(--color-background);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(93, 78, 55, 0.1);
    text-decoration: none;
    color: inherit;
    transition: all 200ms ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-accent);
  }

  .service-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    background: var(--color-surface);
    border-radius: 50%;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
    box-shadow: var(--shadow-sm);
  }

  .service-card h3 {
    margin-bottom: var(--space-2);
    color: var(--color-text);
  }

  .service-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    flex-grow: 1;
  }

  .service-link {
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.875rem;
  }

  /* Before/After */
  .ba-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 48rem) {
    .ba-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .ba-item {
    text-align: center;
  }

  .ba-image {
    position: relative;
    aspect-ratio: 16/10;
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-4);
  }

  .ba-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ba-label {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    background: var(--color-primary);
    color: var(--color-surface);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ba-image.after .ba-label {
    background: var(--color-secondary);
  }

  .ba-caption {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Reviews */
  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 48rem) {
    .reviews-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .review-card {
    background: var(--color-background);
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(93, 78, 55, 0.1);
  }

  .review-stars {
    display: flex;
    gap: var(--space-1);
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .review-text {
    font-size: 0.9375rem;
    color: var(--color-text);
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }

  .review-author {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .review-author strong {
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .review-author span {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  /* Service Areas */
  .areas {
    background: var(--color-surface);
  }

  .areas-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
    list-style: none;
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  @media (min-width: 48rem) {
    .areas-list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 64rem) {
    .areas-list {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .areas-list li {
    padding: var(--space-3) var(--space-4);
    background: var(--color-background);
    border-radius: var(--radius-md);
    font-weight: 500;
    font-size: 0.875rem;
  }

  /* FAQ */
  .faq-list {
    max-width: 800px;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid rgba(93, 78, 55, 0.15);
  }

  .faq-item:first-child {
    border-top: 1px solid rgba(93, 78, 55, 0.15);
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: var(--space-6) 0;
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text);
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    list-style: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question:hover {
    color: var(--color-primary);
  }

  .faq-icon {
    flex-shrink: 0;
    transition: transform 200ms ease;
    color: var(--color-text-muted);
  }

  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding-bottom: var(--space-6);
  }

  .faq-answer p {
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.7;
  }

  /* Contact Form */
  .contact-form {
    max-width: 640px;
    margin: 0 auto;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 48rem) {
    .form-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .form-group:last-child {
    margin-bottom: 0;
  }

  .form-group label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .required {
    color: #C45B5B;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: var(--space-3) var(--space-4);
    border: 2px solid rgba(93, 78, 55, 0.2);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-surface);
    transition: border-color 150ms ease;
  }

