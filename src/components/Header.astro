---
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="Oak Ridge Roofing Co. — Home">
      <span class="logo-primary">Oak Ridge</span>
      <span class="logo-secondary">Roofing Co.</span>
    </a>

    <nav class="nav-desktop" aria-label="Main navigation">
      <a href="/">Home</a>
      <a href="/services">Services</a>
      <a href="/repair">Roof Repair</a>
      <a href="/storm-damage">Storm Damage</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </nav>

    <a href="tel:+15551234567" class="btn-call">
      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
      </svg>
      <span>Call Now</span>
    </a>

    <button class="nav-mobile-toggle" id="mobileToggle" aria-label="Open menu" aria-expanded="false" type="button">
      <svg class="icon-menu" aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
        <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/>
      </svg>
      <svg class="icon-close" aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" style="display: none;">
        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Navigation Drawer -->
  <nav class="nav-mobile" id="mobileNav" aria-label="Mobile navigation">
    <a href="/">Home</a>
    <a href="/services">Services</a>
    <a href="/repair">Roof Repair</a>
    <a href="/storm-damage">Storm Damage</a>
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <a href="tel:+15551234567" class="mobile-call">Call Now</a>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobileToggle');
  const nav = document.getElementById('mobileNav');
  const iconMenu = toggle?.querySelector('.icon-menu');
  const iconClose = toggle?.querySelector('.icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    if (iconMenu) iconMenu.style.display = isOpen ? 'none' : 'block';
    if (iconClose) iconClose.style.display = isOpen ? 'block' : 'none';
  });

  // Close mobile nav when clicking a link
  nav?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      nav.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      if (iconMenu) iconMenu.style.display = 'block';
      if (iconClose) iconClose.style.display = 'none';
    });
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
    position: relative;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-4);
    gap: var(--space-4);
  }

  .logo {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-primary);
    z-index: 101;
    position: relative;
  }

  .logo-primary {
    font-family: var(--font-headline);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .logo-secondary {
    font-family: var(--font-headline);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  /* Desktop nav — hidden on mobile */
  .nav-desktop {
    display: none;
    gap: var(--space-8);
  }

  @media (min-width: 48rem) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-desktop a {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    transition: color 150ms ease, padding-top 150ms ease;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
  }

  .nav-desktop a:hover,
  .nav-desktop a:focus-visible {
    color: var(--color-primary);
    background: rgba(93, 78, 55, 0.06);
  }

  /* CTA Button */
  .btn-call {
    display: none;
    align-items: center;
    gap: var(--space-2);
    background: var(--color-accent);
    color: var(--color-primary);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    text-decoration: none;
    min-height: 44px;
    transition: filter 150ms ease;
  }

  .btn-call:hover,
  .btn-call:focus-visible {
    filter: brightness(0.95);
  }

  @media (min-width: 48rem) {
    .btn-call {
      display: flex;
    }
  }

  /* Mobile toggle — visible on mobile */
  .nav-mobile-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    border-radius: var(--radius-sm);
    z-index: 101;
  }

  .nav-mobile-toggle:hover {
    background: rgba(93, 78, 55, 0.06);
  }

  @media (min-width: 48rem) {
    .nav-mobile-toggle {
      display: none;
    }
  }

  /* Mobile Navigation Drawer */
  .nav-mobile {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-surface);
    box-shadow: var(--shadow-md);
    padding: var(--space-4) var(--space-4) var(--space-6);
    flex-direction: column;
  }

  .nav-mobile.open {
    display: flex;
  }

  @media (min-width: 48rem) {
    .nav-mobile {
      display: none !important;
    }
  }

  .nav-mobile a {
    display: block;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    padding: var(--space-4) var(--space-2);
    border-bottom: 1px solid rgba(93, 78, 55, 0.1);
    transition: color 150ms ease;
  }

  .nav-mobile a:last-child {
    border-bottom: none;
  }

  .nav-mobile a:hover {
    color: var(--color-primary);
  }

  .nav-mobile .mobile-call {
    display: block;
    background: var(--color-accent);
    color: var(--color-primary);
    font-weight: 600;
    text-align: center;
    margin-top: var(--space-4);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border-bottom: none;
  }
</style>
